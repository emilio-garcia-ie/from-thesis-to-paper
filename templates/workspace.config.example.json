{
  "workspaceName": "my-thesis-workspace",
  "workspaceSlug": "my-thesis-workspace",
  "repoRoot": "/path/to/your-writable-project",
  "workflowProfile": "paper_audit",
  "writingMode": "thesis_adapt",
  "overleafPaper": {
    "projectId": "",
    "displayName": "my-thesis-workspace"
  },
  "copyPolicy": {
    "maxArtifactMb": 500,
    "allowSymlinks": false
  },
  "readOnlyRoots": [
    "/path/to/thesis-notebooks",
    "/path/to/verification-data"
  ],
  "thesis": {
    "source": "local|overleaf|both",
    "overleafProjectId": "",
    "mainTexPath": "Capitulos/Resultados.tex"
  },
  "paper": {
    "dir": "paper",
    "mainTex": "main.tex",
    "activeVenue": "primary",
    "venueProfiles": {
      "primary": {
        "id": "user_defined_journal",
        "displayName": "Journal full name",
        "authorGuidelinesUrl": "https://example.com/journal/author-guidelines",
        "mainTex": "main_journal.tex",
        "guidelines": "paper/JOURNAL_GUIDELINES.md",
        "templateSource": "local_path",
        "templatePath": "paper/latex/vendor/",
        "templateDeferred": false,
        "build": "scripts/paper/build_primary.sh"
      },
      "alternate": {
        "id": "user_defined_preprint",
        "mainTex": "main_preprint.tex",
        "guidelines": "paper/PREPRINT_GUIDELINES.md",
        "build": "scripts/paper/build_preprint.sh"
      }
    }
  },
  "packs": [],
  "evidence": {
    "catalog": "memory/thesis_experiment_catalog.md",
    "lineageCsv": "experimentos/evidence/log_lineage.csv"
  },
  "hooks": {
    "lineageBuild": "scripts/archaeology/build_log_lineage.py",
    "tables": "scripts/paper/export_tables_from_catalog.py",
    "evidence": "scripts/paper/build_evidence_bundle.py",
    "figures": "scripts/paper/generate_figures.py",
    "compile": "scripts/paper/build_primary.sh"
  }
}
