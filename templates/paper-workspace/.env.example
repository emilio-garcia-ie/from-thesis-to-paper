# Copy to .env (gitignored) — never commit real credentials.
# Used by optional Overleaf MCP and local solver tooling.

# --- Overleaf (optional MCP) ---
# Paper project id: 24-char hex from Overleaf URL (must match overleafPaper in fttp.config.json)
OVERLEAF_EMAIL=you@example.com
OVERLEAF_PASSWORD=your-overleaf-password-here

# Thesis project (read-only archaeology) — different from paper project
OVERLEAF_THESIS_PROJECT_ID=

# Paper project (SA12 sync target) — same slug as workspaceSlug / display name
# OVERLEAF_PAPER_PROJECT_ID=

# Optional: override MCP binary if not on PATH
# OVERLEAF_MCP_BIN=/path/to/overleaf-mcp

# --- Read-only roots (documentation only; authoritative list is fttp.config.json) ---
# READ_ONLY_ROOT_1=/path/to/thesis-notebooks
# READ_ONLY_ROOT_2=/path/to/verification-data

# --- Gurobi (optional; required only for optimization-or pack / solver replay) ---
# GRB_LICENSE_FILE=/path/to/gurobi.lic
